# Convex deployment URL (required)
# Get this from your Convex dashboard or `npx convex dev` output
#
# For cloud deployments:
VITE_CONVEX_URL=https://your-deployment.convex.cloud
#
# For local development (Convex local backend):
# VITE_CONVEX_URL=http://localhost:3210

# Convex deploy key (for CI/CD)
# CONVEX_DEPLOY_KEY=

# Note: Jira credentials are Convex server-side environment variables, NOT Vercel env vars.
# Set them with: npx convex env set JIRA_API_TOKEN "your-token"
# JIRA_API_TOKEN=
# JIRA_EMAIL=
# JIRA_BASE_URL=
