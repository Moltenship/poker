{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "react", "react-perf", "oxc", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error",
    "restriction": "error",
    "nursery": "off"
  },
  "env": {
    "browser": true,
    "es2024": true
  },
  "rules": {
    "no-importing-vitest-globals": "off",
    "react-in-jsx-scope": "off",
    "no-ternary": "off",
    "no-magic-numbers": "off",
    "no-optional-chaining": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "jsx-max-depth": "off",
    "jsx-filename-extension": "off",
    "explicit-function-return-type": "off",
    "explicit-module-boundary-types": "off",
    "func-style": "off",
    "require-hook": "off",
    "no-console": "off",
    "id-length": "off",
    "no-async-await": "off",
    "jsx-no-new-function-as-prop": "off",
    "no-rest-spread-properties": "off",
    "require-test-timeout": "off",
    "jsx-props-no-spreading": "off",
    "max-statements": "off",
    "max-lines-per-function": "off",
    "complexity": "off",
    "max-lines": "off",
    "max-params": "off",
    "no-multi-comp": "off",
    "only-export-components": "off",
    "require-top-level-describe": "off",
    "valid-title": "off",
    "prefer-strict-boolean-matchers": "off",
    "consistent-type-imports": "off",
    "no-unescaped-entities": "off",
    "prefer-destructuring": "off",
    "no-undefined": "off",
    "no-nested-ternary": "off",
    "jsx-no-new-object-as-prop": "off",
    "jsx-no-new-array-as-prop": "off",
    "require-to-throw-message": "off",
    "no-array-index-key": "off",
    "button-has-type": "off",
    "no-negated-condition": "off",
    "prefer-template": "off",
    "no-empty-function": "off",
    "no-use-before-define": "off",
    "exhaustive-deps": "off",
    "no-non-null-assertion": "off",
    "init-declarations": "off",
    "no-plusplus": "off",
    "no-continue": "off",
    "no-await-in-loop": "off",
    "no-shadow": "off",
    "require-await": "off"
  },
  "ignorePatterns": ["convex/_generated/**", "dist/**", "node_modules/**"]
}
